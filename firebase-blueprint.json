{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "premium", "admin"] },
        "streak": { "type": "number" },
        "lastLessonDate": { "type": "string" }
      },
      "required": ["uid", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    }
  }
}
