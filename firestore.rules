rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - The user's ID
    //   - role: string (required, 'user' | 'premium' | 'admin') - The user's role
    //   - streak: number (optional) - The user's current streak
    //   - lastLessonDate: string (optional) - The date of the last completed lesson
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "thestorymasterofficial@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.role in ['user', 'premium', 'admin'] &&
             (!('streak' in data) || data.streak is number) &&
             (!('lastLessonDate' in data) || data.lastLessonDate is string) &&
             (!('isPro' in data) || data.isPro is bool) &&
             (!('completedSessions' in data) || data.completedSessions is list);
    }

    function isValidFeedback(data) {
      return data.userId == request.auth.uid &&
             data.rating is number &&
             data.rating >= 1 && data.rating <= 5 &&
             (!('text' in data) || data.text is string) &&
             (!('keywords' in data) || data.keywords is list);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
      allow list: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
