rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - The user's ID
    //   - role: string (required, 'user' | 'premium' | 'admin') - The user's role
    //   - streak: number (optional) - The user's current streak
    //   - lastLessonDate: string (optional) - The date of the last completed lesson
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "thestorymasterofficial@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'role', 'streak', 'lastLessonDate']) &&
             data.uid is string &&
             data.role in ['user', 'premium', 'admin'] &&
             (!('streak' in data) || data.streak is number) &&
             (!('lastLessonDate' in data) || data.lastLessonDate is string);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && isOwner(userId) && uidUnchanged() && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && isOwner(userId) && uidNotModified() && ((request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
